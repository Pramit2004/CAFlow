# ─── BACKEND ────────────────────────────────────────────────────────────────
# Server
NODE_ENV=development
PORT=8000

# Supabase (Postgres)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Clerk (Auth)
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=wzz

# Cloudflare R2 (File Storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=caflow-files
R2_PUBLIC_URL=https://files.caflow.app

# Upstash Redis (BullMQ)
UPSTASH_REDIS_URL=https://[ref].upstash.io
UPSTASH_REDIS_TOKEN=

# Resend (Email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@caflow.app

# Razorpay (Payments)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Fast2SMS (SMS)
FAST2SMS_API_KEY=

# App
APP_URL=http://localhost:5173
CLIENT_PORTAL_URL=http://localhost:5174
TOKEN_SECRET=change-this-to-random-256-bit-secret

# ─── FRONTEND ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_APP_URL=http://localhost:5173
VITE_CLIENT_PORTAL_URL=http://localhost:5174
